{
  "info": {
    "name": "Proyecto Backend",
    "description": "Colección de endpoints: Auth, Users y Cursos",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registro",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "nombre", "value": "Rubén Test", "type": "text" },
                { "key": "email", "value": "ejemplo@test.com", "type": "text" },
                { "key": "password", "value": "12345678", "type": "text" },
                { "key": "image", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ejemplo@test.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Obtener mi perfil",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/api/users/me", "host": ["{{base_url}}"], "path": ["api", "users", "me"] }
          }
        },
        {
          "name": "Editar mi perfil",
          "request": {
            "method": "PATCH",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "nombre", "value": "Nuevo Nombre", "type": "text" },
                { "key": "image", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/api/users/me", "host": ["{{base_url}}"], "path": ["api", "users", "me"] }
          }
        },
        {
          "name": "Eliminar mi cuenta",
          "request": {
            "method": "DELETE",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/api/users/me", "host": ["{{base_url}}"], "path": ["api", "users", "me"] }
          }
        },
        {
          "name": "Guardar curso en mi lista",
          "request": {
            "method": "POST",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/api/users/me/cursos/:cursoId", "host": ["{{base_url}}"], "path": ["api", "users", "me", "cursos", ":cursoId"], "variable": [{ "key": "cursoId", "value": "" }] }
          }
        },
        {
          "name": "Listar usuarios (admin)",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] }
          }
        },
        {
          "name": "Eliminar usuario (admin)",
          "request": {
            "method": "DELETE",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/api/users/:id", "host": ["{{base_url}}"], "path": ["api", "users", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Cambiar rol (admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"admin\"\n}" },
            "url": { "raw": "{{base_url}}/api/users/:id/role", "host": ["{{base_url}}"], "path": ["api", "users", ":id", "role"], "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    },
    {
      "name": "Cursos",
      "item": [
        {
          "name": "Listar cursos",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/api/cursos", "host": ["{{base_url}}"], "path": ["api", "cursos"] }
          }
        },
        {
          "name": "Obtener curso por id",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/api/cursos/:id", "host": ["{{base_url}}"], "path": ["api", "cursos", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Crear curso (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Nuevo curso\",\n  \"descripcion\": \"Descripción del curso\",\n  \"categoria\": \"Backend\",\n  \"duracion\": 10,\n  \"nivel\": \"principiante\",\n  \"instructor\": \"Nombre Instructor\",\n  \"precio\": 29.99\n}"
            },
            "url": { "raw": "{{base_url}}/api/cursos", "host": ["{{base_url}}"], "path": ["api", "cursos"] }
          }
        },
        {
          "name": "Actualizar curso (admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Curso actualizado\",\n  \"descripcion\": \"Descripción actualizada\",\n  \"categoria\": \"Backend\",\n  \"duracion\": 15,\n  \"nivel\": \"intermedio\",\n  \"instructor\": \"Nombre Instructor\",\n  \"precio\": 39.99\n}"
            },
            "url": { "raw": "{{base_url}}/api/cursos/:id", "host": ["{{base_url}}"], "path": ["api", "cursos", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Eliminar curso (admin)",
          "request": {
            "method": "DELETE",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/api/cursos/:id", "host": ["{{base_url}}"], "path": ["api", "cursos", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    }
  ]
}